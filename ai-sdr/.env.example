# ============================================================
# AI SDR Platform - Production Environment Variables
# ============================================================
# Copy this to .env and fill in your values

# --- App ---
APP_NAME=AI SDR
APP_VERSION=1.0.0
DEBUG=false
IS_PRODUCTION=true

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[YOUR-HOST].supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST].supabase.co:5432/postgres

# --- Supabase (for Auth, Storage, Realtime) ---
SUPABASE_URL=https://[YOUR-PROJECT].supabase.co
SUPABASE_SERVICE_KEY=[your-service-role-key]
SUPABASE_ANON_KEY=[your-anon-key]

# --- Redis / Queue (Upstash) ---
REDIS_URL=redis://localhost:6379/0
UPSTASH_REDIS_URL=https://[YOUR-UPSTASH-URL].upstash.io
UPSTASH_REDIS_TOKEN=[your-upstash-token]

# --- Auth ---
SECRET_KEY=[generate-a-random-64-char-hex-secret]
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI Providers (at least one required) ---
TOGETHER_API_KEY=tgp_[your-key]
TOGETHER_MODEL=meta-llama/Llama-3.1-8B-Instruct
OPENAI_API_KEY=sk-[your-key]
ANTHROPIC_API_KEY=sk-ant-[your-key]
GOOGLE_AI_API_KEY=AIza[your-key]
OPENROUTER_API_KEY=sk-or-v1-[your-key]
OPENROUTER_MODEL=deepseek/deepseek-v4-flash-free
DEFAULT_AI_MODEL=deepseek-v4-flash-free
AI_TOKEN_BUDGET_MONTHLY=100000000

# --- Google OAuth ---
GOOGLE_CLIENT_ID=[your-client-id].apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=[your-client-secret]
GOOGLE_REDIRECT_URI=https://api.offdx.in/api/v1/auth/google/callback

# --- Gmail ---
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=gmail_token.json

# --- VAPI ---
VAPI_API_KEY=[your-vapi-key]
VAPI_BASE_URL=https://api.vapi.ai

# --- Apollo ---
APOLLO_API_KEY=[your-apollo-key]

# --- AWS ---
AWS_ACCESS_KEY_ID=[your-aws-key]
AWS_SECRET_ACCESS_KEY=[your-aws-secret]
AWS_REGION=us-east-1
AWS_S3_BUCKET=aisdr-uploads

# --- Frontend ---
FRONTEND_URL=https://app.offdx.in

# --- Email Defaults ---
DEFAULT_SMTP_HOST=smtp.hostinger.com
DEFAULT_SMTP_PORT=465
DEFAULT_SMTP_USERNAME=hello@offdx.in
DEFAULT_SMTP_PASSWORD=[your-email-password]
DEFAULT_SMTP_SENDER_EMAIL=hello@offdx.in
DEFAULT_SMTP_SENDER_NAME=AI SDR

# --- Tracking ---
TRACKING_DOMAIN=track.offdx.in

# --- Sentry ---
SENTRY_DSN=https://[key]@o[org].ingest.sentry.io/[project]
